<Page x:Class="Demka.pages.ProductListAdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Demka.pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProductListAdminPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="75"></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <TextBlock Grid.Column="3" Name="userBlock" HorizontalAlignment="Center" TextWrapping="Wrap" Text="" VerticalAlignment="Center"/>
        <TextBlock Grid.Column="1" Grid.ColumnSpan="3" Text="Список бурмалды" VerticalAlignment="Center" HorizontalAlignment="Center"/>
        <Button Name="btnBack" Grid.Column="5" Content="Назад" Click="btnBack_Click"></Button>
        <Button Name="btnToOrdersPage" Content="На заказы" Grid.Column="4" Grid.Row="1" Margin="10,24,10,24" Click="btnToOrdersPage_Click"></Button>
        <Image Source="/resources/icon.ico"></Image>
        <ComboBox Name="PriceSortProductsComboBox" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="1" SelectionChanged="SortProductsComboBox_SelectionChanged" Width="140">
            <ComboBoxItem Content="По возрастанию по на складе"
                          FontSize="18"/>
            <ComboBoxItem Content="По убыванию по на складе"
                          FontSize="18"/>
            <ComboBoxItem Content="По возрастанию по цене"
                          FontSize="18"/>
            <ComboBoxItem Content="По убыванию по цене"
                          FontSize="18"/>
            <ComboBoxItem Content="Сброс сортировки"
                          FontSize="18"/>
        </ComboBox>

        <ComboBox Name="SupplierCmb" Grid.Column="1" Grid.Row="1" ItemsSource="{Binding supplier}" VerticalAlignment="Center" HorizontalAlignment="Center" SelectionChanged="SupplierCmb_SelectionChanged" Width="140" Height="27">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock FontSize="20"
                               Text="{Binding name}"/>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <TextBox Name="searchTovar" Grid.Row="1" Grid.Column="3" Margin="10,24,10,24" TextChanged="searchTovar_TextChanged"/>

        <Button Name="btnAdd" Content="Добавить" Grid.Row="2" Margin="10,10,63,37" Click="btnAdd_Click" ></Button>
        <Button Name="btnEdit" Content="Редактировать" Grid.Row="3" Margin="10,10,63,38" Click="btnEdit_Click" ></Button>
        <Button Name="btnDelete" Content="Удалить" Grid.Row="4" Margin="10,10,63,37" Click="btnDelete_Click" ></Button>

        <ListView Name="tovarLV" Grid.ColumnSpan="6" Grid.Row="2" Grid.RowSpan="4" ItemsSource="{Binding tovar}" HorizontalAlignment="Center">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black" BorderThickness="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <Border BorderBrush="Black" BorderThickness="2">
                                <Image Height="150"
                                   Width="150"
                                   Margin="10 0">
                                    <Image.Source>
                                        <Binding Path="image">
                                            <Binding.TargetNullValue>
                                                <ImageSource>/resources/picture.png</ImageSource>
                                            </Binding.TargetNullValue>
                                        </Binding>
                                    </Image.Source>
                                </Image>
                            </Border>

                            <Border BorderBrush="Black" BorderThickness="2" Grid.Column="1">
                                <StackPanel Grid.Column="1"
            Width="1000">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Category.name}"
               FontSize="18"/>
                                        <TextBlock Text="{Binding name, StringFormat={} | {0}}"
               FontSize="18"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding description, StringFormat={}Описание товара: {0}}"
           FontSize="18"/>
                                    <TextBlock Text="{Binding Manufacturer.name, StringFormat={}Производитель: {0}}"
           FontSize="18"/>
                                    <TextBlock Text="{Binding Supplier.name, StringFormat={}Поставщик: {0}}"
           FontSize="18"/>
                                    <TextBlock Text="{Binding Unit.name, StringFormat={}Единица измерения: {0}}"
           FontSize="18"/>
                                    <TextBlock Text="{Binding price, StringFormat={}Цена: {0}}"
           FontSize="18"/>
                                    <TextBlock Text="{Binding quantity, StringFormat={}Количество на складе: {0}}"
           FontSize="18"/>
                                </StackPanel>
                            </Border>


                            <Border BorderBrush="Black" BorderThickness="2" Grid.Column="2">
                                <StackPanel Grid.Column="2" Width="100" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding discount, StringFormat={}Скидка: {0}}"
                                       FontSize="18"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
