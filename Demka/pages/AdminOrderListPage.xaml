<Page x:Class="Demka.pages.AdminOrderListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Demka.pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AdminOrderListPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="75"></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <TextBlock Grid.Column="3" Name="userBlock" HorizontalAlignment="Center" TextWrapping="Wrap" Text="" VerticalAlignment="Center"/>
        <TextBlock Grid.Column="1" Grid.ColumnSpan="3" Text="Список заказов" VerticalAlignment="Center" HorizontalAlignment="Center"/>
        <Button Name="btnBack" Grid.Column="5" Content="Назад" Click="btnBack_Click"></Button>
        <Image Source="/resources/icon.ico"></Image>

        <Button Name="btnAdd" Content="Добавить" Grid.Row="2" Margin="10,10,63,37" Click="btnAdd_Click" ></Button>
        <Button Name="btnEdit" Content="Редактировать" Grid.Row="3" Margin="10,10,63,38" Click="btnEdit_Click" ></Button>
        <Button Name="btnDelete" Content="Удалить" Grid.Row="4" Margin="10,10,63,37" Click="btnDelete_Click" ></Button>

        <ListView Name="orderLV" Grid.ColumnSpan="6" Grid.Row="2" Grid.RowSpan="4" ItemsSource="{Binding orders}" HorizontalAlignment="Center">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black" BorderThickness="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <Border BorderBrush="Black" BorderThickness="2">
                                <StackPanel Grid.Column="1"
            Width="1000">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding dateStart}"
               FontSize="18"/>
                                        <TextBlock Text="{Binding dateEnd, StringFormat={} | {0}}"
               FontSize="18"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Pvz.index, StringFormat={}Индекс: {0}}"
           FontSize="18"/>
                                    <TextBlock Text="{Binding Pvz.City.name, StringFormat={}Город: {0}}"
           FontSize="18"/>
                                    <TextBlock Text="{Binding Pvz.Street.name, StringFormat={}Улица: {0}}"
           FontSize="18"/>
                                    <TextBlock Text="{Binding Pvz.house, StringFormat={}Дом: {0}}"
           FontSize="18"/>
                                    <TextBlock Text="{Binding User.name, StringFormat={}Заказчик: {0}}"
           FontSize="18"/>
                                    <TextBlock Text="{Binding code, StringFormat={}Код заказа: {0}}"
           FontSize="18"/>
                                    <TextBlock Text="{Binding Status.name, StringFormat={}Статус заказа: {0}}"
           FontSize="18"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
