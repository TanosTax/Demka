<Window x:Class="Demka.windows.AddProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Demka.windows"
        mc:Ignorable="d"
        Title="AddProductWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <TextBlock Text="Добавление товара"
                   FontSize="22"
                   Grid.Column="2"
                   Grid.ColumnSpan="4"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
        <Image Source="/Resources/Icon.png"/>

        <Image Grid.Row="1"
               Grid.ColumnSpan="3"
               Grid.RowSpan="2"
               Name="productImage"/>
        <Button Grid.Row="3"
                Grid.ColumnSpan="2"
                Content="Выбрать фото"
                Name="ChoosePhotoBtn"
                Click="ChoosePhotoBtn_Click"/>

        <TextBlock Text="Наименование товара"
                   Grid.Row="4"
                   Grid.ColumnSpan="3"
                   FontSize="18"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
        <TextBox x:Name="nameProdTb"
                 Grid.Row="5"
                 Grid.ColumnSpan="3"
                 Margin="30 10"
                 VerticalContentAlignment="Center"/>
        <TextBlock Text="Категория товара"
                   Grid.Row="6"
                   Grid.ColumnSpan="3"
                   FontSize="18"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
        <ComboBox x:Name="categoryCmb"
                  Grid.Row="7"
                  Grid.ColumnSpan="3"
                  Margin="30 10"
                  VerticalContentAlignment="Center"
                  ItemsSource="{Binding categories}">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding name}"
                               FontSize="18"/>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        <TextBlock Text="Описание товара"
                   Grid.Column="3"
                   Grid.Row="1"
                   Grid.ColumnSpan="3"
                   FontSize="18"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
        <TextBox x:Name="descriptionTb"
                 Grid.Column="3"
                 Grid.Row="2"
                 Grid.ColumnSpan="3"
                 Grid.RowSpan="2"
                 Margin="30 10"
                 VerticalContentAlignment="Center"/>
        <TextBlock Text="Производитель"
                   Grid.Column="3"
                   Grid.Row="4"
                   Grid.ColumnSpan="3"
                   FontSize="18"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
        <ComboBox x:Name="manufacturerCmb"
                  Grid.Row="5"
                  Grid.Column="3"
                  Grid.ColumnSpan="3"
                  Margin="30 10"
                  VerticalContentAlignment="Center"
                  ItemsSource="{Binding manufacturers}">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding name}"
                               FontSize="18"/>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        <TextBlock Text="Поставщик"
                   Grid.Column="3"
                   Grid.Row="6"
                   Grid.ColumnSpan="3"
                   FontSize="18"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
        <ComboBox x:Name="supplierCmb"
                   Grid.Row="7"
                   Grid.Column="3"
                   Grid.ColumnSpan="3"
                   Margin="30 10"
                   VerticalContentAlignment="Center"
                   ItemsSource="{Binding suppliers}">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding name}"
                                FontSize="18"/>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        <TextBlock Text="Цена"
                   Grid.Column="6"
                   Grid.Row="1"
                   FontSize="18"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
        <TextBox x:Name="priceTb"
                 Grid.Column="6"
                 Grid.Row="2"
                 Margin="5"
                 VerticalContentAlignment="Center"/>
        <TextBlock Text="Скидка"
                   Grid.Column="7"
                   Grid.Row="1"
                   FontSize="18"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
        <TextBox x:Name="discountTb"
                 Grid.Column="7"
                 Grid.Row="2"
                 Margin="5"
                 VerticalContentAlignment="Center"/>
        <TextBlock Text="Кол-во на складе"
                   TextWrapping="Wrap"
                   Grid.Column="6"
                   Grid.Row="3"
                   FontSize="18"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   VerticalAlignment="Center"/>
        <TextBox x:Name="wshCountTb"
                 Grid.Column="6"
                 Grid.Row="4"
                 Margin="5"
                 VerticalContentAlignment="Center"/>
        <TextBlock Text="Единица измерения"
                   TextWrapping="Wrap"
                   Grid.Column="7"
                   Grid.Row="3"
                   FontSize="18"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   VerticalAlignment="Center"/>
        <ComboBox x:Name="unitTb"
                 Grid.Column="7"
                 Grid.Row="4"
                 Margin="5"
                 VerticalContentAlignment="Center"
                  ItemsSource="{Binding units}">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding name}"
                               FontSize="18"/>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        <Button x:Name="SaveBtn"
                Click="SaveBtn_Click"
                Grid.Column="6"
                Grid.ColumnSpan="2"
                Grid.Row="5"
                Grid.RowSpan="2"
                Height="70"
                Width="150"
                Content="Сохранить"
                FontSize="18"
                Background="#00FA9A"/>
    </Grid>
</Window>
