<Window x:Class="Demka.windows.EditOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Demka.windows"
        mc:Ignorable="d"
        Title="EditOrderWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <TextBlock Text="Добавление товара"
                   FontSize="22"
                   Grid.Column="2"
                   Grid.ColumnSpan="4"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
        <Image Source="/Resources/Icon.png"/>

        <Image Grid.Row="1"
               Grid.ColumnSpan="3"
               Grid.RowSpan="2"
               Name="productImage"/>

        <TextBlock Text="Дата заказа"
                   Grid.ColumnSpan="2"
                   FontSize="18"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top" Margin="94,35,0,0" Grid.RowSpan="2"/>

        <Calendar  Name="dateStartCal" Grid.Row="1"
                 Grid.ColumnSpan="3" Margin="0,5,0,31" Grid.RowSpan="4">
        </Calendar>

        <TextBlock Text="Дата получения"
                   Grid.Row="4"
                   FontSize="18"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top" Margin="76,8,0,0" Grid.ColumnSpan="3"/>

        <Calendar  Name="dateEndCal" Grid.Row="4"
                  Grid.ColumnSpan="3" Margin="-10,37,10,15" Grid.RowSpan="4">
        </Calendar>

        <TextBlock Text="Пукнт выдачи"
                   Grid.Column="3"
                   Grid.Row="1"
                   Grid.ColumnSpan="3"
                   FontSize="18"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>



        <ComboBox Name="pzvComboBox" Grid.Column="3" Grid.Row="2" Grid.ColumnSpan="3" Grid.RowSpan="2" ItemsSource="{Binding pvzs}" VerticalAlignment="Center" HorizontalAlignment="Center" Width="240" Height="54">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock FontSize="20"
                               Text="{Binding Street.name}"/>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>



        <TextBlock Text="Пользователь"
                   Grid.Column="3"
                   Grid.Row="4"
                   Grid.ColumnSpan="3"
                   FontSize="18"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>

        <ComboBox Name="userComboBox" Grid.Column="3" Grid.Row="5" Grid.RowSpan="2" ItemsSource="{Binding users}" VerticalAlignment="Top" HorizontalAlignment="Left" Width="240" Height="54" Margin="20,10,0,0" Grid.ColumnSpan="3">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock FontSize="20"
                               Text="{Binding name}"/>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>


        <TextBlock Text="Код"
                   Grid.Column="3"
                   Grid.Row="6"
                   Grid.ColumnSpan="3"
                   FontSize="18"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>

        <TextBox Name="codeTxtBox" Grid.Column="3"
                 HorizontalAlignment="Left" Grid.Row="7"
                 TextWrapping="Wrap" Text="" VerticalAlignment="Center" Width="220" Height="36" Grid.ColumnSpan="3" Margin="30,0,0,0"/>




        <Button x:Name="SaveBtn"
                Click="SaveBtn_Click"
                Grid.Column="6"
                Grid.ColumnSpan="2"
                Grid.Row="5"
                Grid.RowSpan="2"
                Height="70"
                Width="150"
                Content="Сохранить"
                FontSize="18"
                Background="#00FA9A"/>
        <TextBlock Text="Статус"
            Grid.Column="6"
            Grid.Row="2"
            FontSize="18"
            HorizontalAlignment="Left"
            VerticalAlignment="Top" Grid.ColumnSpan="2" Margin="23,24,0,0"/>

        <ComboBox Name="statusComboBox" Grid.Column="5" Grid.Row="3" Grid.ColumnSpan="3" Grid.RowSpan="2" ItemsSource="{Binding statuses}" VerticalAlignment="Top" HorizontalAlignment="Left" Width="222" Height="54" Margin="68,38,0,0">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock FontSize="20"
                               Text="{Binding name}"/>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

    </Grid>
</Window>
